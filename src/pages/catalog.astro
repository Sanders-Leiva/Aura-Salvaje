---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import { supabase } from '../lib/supabase';

// Traemos todos los productos desde Supabase
const { data: productos, error } = await supabase
  .from('products')
  .select('*')
  .order('created_at', { ascending: false });

if (error) console.error('Error fetching catalog:', error);
const catalogo = productos || [];
---

<BaseLayout title="Aura Salvaje - Catálogo">
  <div class="max-w-6xl mx-auto py-8 px-4 md:py-12 md:px-12">
    <div class="text-center mb-10">
      <h1 class="text-3xl md:text-4xl font-black text-[#6D4C41] tracking-widest mb-4">NUESTRA COLECCIÓN</h1>
      <p class="text-gray-500 max-w-2xl mx-auto font-medium">Encuentra la pieza perfecta que resuene con tu energía y estilo personal.</p>
    </div>

    <CategoryFilter />

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
      {catalogo.map((producto: any) => (
        <ProductCard 
          id={producto.id}
          title={producto.name} 
          price={producto.price} 
          imageUrl={producto.image_url}
          description={producto.description}
        />
      ))}
    </div>
  </div>
</BaseLayout>
