---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Aura Salvaje - Contacto">
  <div class="max-w-4xl mx-auto py-12 px-6 md:px-12 min-h-[70vh] flex flex-col justify-center">
    <div class="text-center mb-12">
      <h1 class="text-3xl md:text-5xl font-black text-[#6D4C41] tracking-widest mb-4 uppercase" style="font-family: 'Playfair Display', serif;">Contáctanos</h1>
      <p class="text-gray-600 max-w-2xl mx-auto font-medium">¿Tienes alguna pregunta, pedido especial o simplemente quieres decir hola? Nos encantaría escucharte.</p>
    </div>

    <div class="max-w-2xl mx-auto bg-white p-8 md:p-12 rounded-3xl shadow-sm border border-amber-50">
      <!-- Información de Contacto -->
      <div class="flex flex-col gap-8 text-center items-center">
        <div>
          <h3 class="text-2xl font-bold text-[#6D4C41] mb-2 tracking-widest">AURA SALVAJE</h3>
          <p class="text-gray-500 mb-8 max-w-sm mx-auto">Bisutería by Audrey Lopez</p>
          
          <div class="flex flex-col items-center gap-6 text-gray-700 w-full">
            
            <a href="https://wa.me/50588888888" target="_blank" class="w-full bg-[#25D366] hover:bg-[#20bd5a] text-white font-bold py-4 px-6 rounded-xl tracking-widest transition-colors shadow-sm flex items-center justify-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
              ENVIAR WHATSAPP (+505 8888 8888)
            </a>

            <div class="flex items-center gap-4 text-gray-700 hover:text-amber-600 transition-colors mt-4">
              <div class="w-10 h-10 bg-amber-50 rounded-full flex items-center justify-center text-amber-600 flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
              </div>
              <a href="#" class="font-medium">@aurasalvaje</a>
            </div>
            
            <div class="flex items-center gap-4 text-gray-700 hover:text-amber-600 transition-colors">
              <div class="w-10 h-10 bg-amber-50 rounded-full flex items-center justify-center text-amber-600 flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <a href="mailto:hola@aurasalvaje.com" class="font-medium">hola@aurasalvaje.com</a>
            </div>
          </div>
        </div>

        <div class="p-6 bg-[#FCF9F2] rounded-2xl border border-amber-100 w-full mt-4">
          <h4 class="font-bold text-[#6D4C41] mb-2 tracking-widest text-sm">HORARIO DE ATENCIÓN</h4>
          <p class="text-sm text-gray-600 leading-relaxed">
            Lunes a Viernes: 9:00 AM - 6:00 PM<br>
            Sábados: 10:00 AM - 2:00 PM<br>
            Domingos: Cerrado
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
