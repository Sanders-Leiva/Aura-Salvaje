---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Aura Salvaje - Contacto">
  <div class="max-w-4xl mx-auto py-12 px-6 md:px-12 min-h-[70vh] flex flex-col justify-center">
    <div class="text-center mb-12">
      <h1 class="text-3xl md:text-5xl font-black text-[#6D4C41] tracking-widest mb-4 uppercase" style="font-family: 'Playfair Display', serif;">Contáctanos</h1>
      <p class="text-gray-600 max-w-2xl mx-auto font-medium">¿Tienes alguna pregunta, pedido especial o simplemente quieres decir hola? Nos encantaría escucharte.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 bg-white p-8 md:p-12 rounded-3xl shadow-sm border border-amber-50">
      <!-- Información de Contacto -->
      <div class="flex flex-col gap-8">
        <div>
          <h3 class="text-xl font-bold text-[#6D4C41] mb-2 tracking-widest">AURA SALVAJE</h3>
          <p class="text-gray-500 mb-6">Bisutería artesanal con intención, hecha a mano por Audrey en Costa Rica.</p>
          
          <div class="flex items-center gap-4 text-gray-700 mb-4 hover:text-amber-600 transition-colors">
            <div class="w-10 h-10 bg-amber-50 rounded-full flex items-center justify-center text-amber-600 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <a href="https://wa.me/50612345678" target="_blank" class="font-medium">+506 1234 5678</a>
          </div>

          <div class="flex items-center gap-4 text-gray-700 mb-4 hover:text-amber-600 transition-colors">
            <div class="w-10 h-10 bg-amber-50 rounded-full flex items-center justify-center text-amber-600 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <a href="mailto:hola@aurasalvaje.com" class="font-medium">hola@aurasalvaje.com</a>
          </div>

          <div class="flex items-center gap-4 text-gray-700 hover:text-amber-600 transition-colors">
            <div class="w-10 h-10 bg-amber-50 rounded-full flex items-center justify-center text-amber-600 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            </div>
            <a href="#" class="font-medium">@aurasalvaje</a>
          </div>
        </div>

        <div class="p-6 bg-[#FCF9F2] rounded-2xl border border-amber-100">
          <h4 class="font-bold text-[#6D4C41] mb-2 tracking-widest text-sm">HORARIO DE ATENCIÓN</h4>
          <p class="text-sm text-gray-600 leading-relaxed">
            Lunes a Viernes: 9:00 AM - 6:00 PM<br>
            Sábados: 10:00 AM - 2:00 PM<br>
            Domingos: Cerrado
          </p>
        </div>
      </div>

      <!-- Formulario -->
      <form class="flex flex-col gap-4">
        <div>
          <label for="name" class="block text-xs font-bold text-gray-500 tracking-widest uppercase mb-1">Tu Nombre</label>
          <input type="text" id="name" name="name" required class="w-full bg-gray-50 border border-gray-200 text-gray-800 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-amber-500/50 focus:border-amber-500 transition-colors" placeholder="Ej. María Pérez">
        </div>
        
        <div>
          <label for="email" class="block text-xs font-bold text-gray-500 tracking-widest uppercase mb-1">Correo Electrónico</label>
          <input type="email" id="email" name="email" required class="w-full bg-gray-50 border border-gray-200 text-gray-800 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-amber-500/50 focus:border-amber-500 transition-colors" placeholder="maria@ejemplo.com">
        </div>

        <div>
          <label for="message" class="block text-xs font-bold text-gray-500 tracking-widest uppercase mb-1">Mensaje</label>
          <textarea id="message" name="message" rows="4" required class="w-full bg-gray-50 border border-gray-200 text-gray-800 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-amber-500/50 focus:border-amber-500 transition-colors resize-none" placeholder="¿En qué te podemos ayudar?"></textarea>
        </div>

        <button type="submit" class="w-full bg-[#D4A373] hover:bg-[#8B5E34] text-white font-bold py-4 rounded-xl tracking-widest transition-colors mt-2 shadow-sm">
          ENVIAR MENSAJE
        </button>
      </form>

    </div>
  </div>
</BaseLayout>
