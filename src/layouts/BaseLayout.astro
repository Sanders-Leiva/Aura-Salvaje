---
import '../styles/global.css';
import CartFlyout from '../components/CartFlyout.astro';
const { title = "Aura Salvaje" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Inter:wght@300;400;500;600;700&family=Great+Vibes&family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#FCF9F2] text-gray-800 font-sans antialiased min-h-screen flex flex-col">
    
    <header class="bg-[#FCF9F2] py-4 px-6 md:px-12 flex justify-between items-center relative z-10 border-b border-gray-200">
      <div class="flex items-center gap-2">
        <div class="font-bold text-3xl md:text-4xl text-amber-700 flex flex-col leading-tight" style="font-family: 'Great Vibes', cursive;">
          <span class="tracking-widest font-normal">Aura Salvaje</span>
          <span class="text-xs text-gray-500 font-normal tracking-widest text-center md:text-left">by Audrey L</span>
        </div>
      </div>
      <nav class="hidden md:block">
        <ul class="flex space-x-6 text-xs font-bold text-gray-600 tracking-widest">
          <li><a href="/" class="hover:text-amber-600 text-amber-600">INICIO</a></li>
          <li><a href="/catalog" class="hover:text-amber-600">TIENDA</a></li>
          <li><a href="#" class="hover:text-amber-600">SOBRE NOSOTRAS</a></li>
          <li><a href="#" class="hover:text-amber-600">BLOG</a></li>
          <li><a href="/contact" class="hover:text-amber-600">CONTACTO</a></li>
        </ul>
      </nav>
      <div class="flex gap-4 md:gap-5 text-gray-700 items-center">
        <a href="/login" class="cursor-pointer hover:scale-110 hover:text-amber-600 transition-transform hidden md:block" title="Iniciar Sesión">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
        <button id="cart-toggle-btn" class="cursor-pointer hover:scale-110 hover:text-amber-600 transition-transform relative outline-none focus:outline-none">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
          <span id="cart-badge-count" class="absolute -top-1 -right-2 bg-amber-600 text-white text-[9px] font-bold w-4 h-4 flex items-center justify-center rounded-full">0</span>
        </button>
        <button id="mobile-menu-btn" class="md:hidden cursor-pointer hover:scale-110 hover:text-amber-600 transition-transform relative outline-none focus:outline-none ml-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </button>
      </div>
    </header>

    <!-- Mobile Navigation Overlay -->
    <div id="mobile-nav-overlay" class="fixed inset-0 bg-white z-50 transform translate-x-full transition-transform duration-300 flex flex-col pt-20 px-8 hidden">
      <button id="close-mobile-menu" class="absolute top-6 right-6 text-gray-500 hover:text-amber-600">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <ul class="flex flex-col space-y-8 text-xl font-black text-[#6D4C41] tracking-widest mt-12 text-center">
        <li><a href="/" class="hover:text-amber-600 block w-full py-2 border-b border-gray-100">INICIO</a></li>
        <li><a href="/catalog" class="hover:text-amber-600 block w-full py-2 border-b border-gray-100">TIENDA</a></li>
        <li><a href="#" class="hover:text-amber-600 block w-full py-2 border-b border-gray-100">SOBRE NOSOTRAS</a></li>
        <li><a href="/contact" class="hover:text-amber-600 block w-full py-2 border-b border-gray-100">CONTACTO</a></li>
        <li><a href="/login" class="hover:text-amber-600 block w-full py-2 text-gray-400 mt-8">ADMINISTRACIÓN</a></li>
      </ul>
    </div>

    <main class="flex-grow w-full">
      <slot />
    </main>

    <footer class="bg-[#8B5E34] text-white py-8 mt-auto flex flex-col items-center justify-center text-center px-4">
      <p class="text-xs md:text-sm tracking-wider mb-2">&copy; 2026 Aura Salvaje. Todos los derechos reservados.</p>
      <a href="/admin" class="text-[10px] text-amber-200/50 hover:text-amber-200 transition-colors uppercase tracking-widest">Panel de Administración</a>
    </footer>

    <CartFlyout />

    <script>
      import { cartQuantity, isCartOpen } from '../store/cart';

      // Update badge
      const badge = document.getElementById('cart-badge-count');
      cartQuantity.subscribe((qty) => {
        if (badge) {
          badge.textContent = qty.toString();
          if (qty > 0) {
            badge.classList.remove('hidden');
          } else {
            badge.classList.add('hidden');
          }
        }
      });

      // Toggle cart
      const cartToggleBtn = document.getElementById('cart-toggle-btn');
      if (cartToggleBtn) {
        cartToggleBtn.addEventListener('click', () => {
          isCartOpen.set(true);
        });
      }

      // Mobile Menu Logic
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const closeMobileBtn = document.getElementById('close-mobile-menu');
      const mobileNavOverlay = document.getElementById('mobile-nav-overlay');

      if (mobileMenuBtn && closeMobileBtn && mobileNavOverlay) {
        mobileMenuBtn.addEventListener('click', () => {
          mobileNavOverlay.classList.remove('hidden');
          // Pequeño delay para permitir que el display:block se aplique antes de animar
          setTimeout(() => mobileNavOverlay.classList.remove('translate-x-full'), 10);
          document.body.style.overflow = 'hidden';
        });

        closeMobileBtn.addEventListener('click', () => {
          mobileNavOverlay.classList.add('translate-x-full');
          setTimeout(() => mobileNavOverlay.classList.add('hidden'), 300);
          document.body.style.overflow = '';
        });
      }
    </script>
  </body>
</html>
