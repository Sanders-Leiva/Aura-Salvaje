---
import '../styles/global.css';
const { title = "Aura Salvaje" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#FCF9F2] text-gray-800 font-sans antialiased min-h-screen flex flex-col">
    
    <header class="bg-[#FCF9F2] py-4 px-6 md:px-12 flex justify-between items-center relative z-10 border-b border-gray-200">
      <div class="flex items-center gap-2">
        <div class="font-bold text-2xl text-amber-700 flex flex-col leading-tight">
          <span class="tracking-widest">AURA SALVAJE</span>
          <span class="text-xs text-gray-500 font-normal tracking-widest">- Bisutería Artesanal -</span>
        </div>
      </div>
      <nav class="hidden md:block">
        <ul class="flex space-x-6 text-xs font-bold text-gray-600 tracking-widest">
          <li><a href="/" class="hover:text-amber-600 text-amber-600">INICIO</a></li>
          <li><a href="/catalog" class="hover:text-amber-600">TIENDA</a></li>
          <li><a href="#" class="hover:text-amber-600">SOBRE NOSOTRAS</a></li>
          <li><a href="#" class="hover:text-amber-600">BLOG</a></li>
          <li><a href="/contact" class="hover:text-amber-600">CONTACTO</a></li>
        </ul>
      </nav>
      <div class="flex gap-5 text-gray-700 items-center">
        <a href="/login" class="cursor-pointer hover:scale-110 hover:text-amber-600 transition-transform" title="Iniciar Sesión">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
        <a href="#" class="cursor-pointer hover:scale-110 hover:text-amber-600 transition-transform">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
        </a>
        <a href="#" class="cursor-pointer hover:scale-110 hover:text-amber-600 transition-transform relative">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
          <span class="absolute -top-1 -right-2 bg-amber-600 text-white text-[9px] font-bold w-4 h-4 flex items-center justify-center rounded-full">0</span>
        </a>
      </div>
    </header>

    <main class="flex-grow w-full">
      <slot />
    </main>

    <footer class="bg-[#8B5E34] text-white py-8 mt-auto flex flex-col items-center justify-center">
      <p class="text-sm tracking-wider mb-2">&copy; 2024 Aura Salvaje. Todos los derechos reservados.</p>
      <a href="/admin" class="text-[10px] text-amber-200/50 hover:text-amber-200 transition-colors uppercase tracking-widest">Panel de Administración</a>
    </footer>

  </body>
</html>
